{
  "name": "circle-union",
  "version": "1.0.0",
  "description": "Fast union of geographic circles into coverage polygons with holes.",
  "type": "module",
  "module": "index.js",
  "main": "circle-union.js",
  "exports": "./index.js",
  "sideEffects": false,
  "files": [
    "index.js",
    "index.d.ts",
    "circle-union.js"
  ],
  "scripts": {
    "pretest": "eslint . && tsc",
    "test": "node --test test/*.test.js",
    "bench": "node bench/bench.js",
    "preview": "node preview/generate.js",
    "build": "rolldown index.js -o circle-union.js -n CircleUnion -f umd"
  },
  "author": "Volodymyr Agafonkin",
  "license": "ISC",
  "dependencies": {
    "flatbush": "^4.6.2",
    "geoflatbush": "^2.2.1"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "eslint-config-mourner": "^5.0.1",
    "rolldown": "^1.1.2",
    "typescript": "^6.0.3"
  }
}
